[Unit]
Description=Llama Server Service (Gemma 4 31B QAT MTP Q4_0 - Unsloth GGUF)
After=network.target

[Service]
User=hermes
WorkingDirectory=/home/hermes/llama

Environment="GGML_CUDA_GRAPH_OPT=0"
Environment="LD_LIBRARY_PATH=/home/hermes/llama/llama.cpp/build/bin"

# Gemma 4 31B QAT MTP profile (port 8080):
#   Base: unsloth QAT UD-Q4_K_XL (16.1 GB) + MTP Q4_0 draft head (267 MB).
#   64K context (safe on 24 GB; weights ~16.5 GB + q4_0 KV ~1.5 GB + overhead ~1 GB ≈ 19 GB).
#   q4_0 K/V cache, native GGUF jinja template, reasoning off.
#   Gemma defaults: temp 1.0, top-p 0.95, top-k 64.
#   MTP n=2 via external draft GGUF (--spec-draft-model + --spec-type draft-mtp).
ExecStart=/home/hermes/llama/llama.cpp/build/bin/llama-server \
  -m /home/hermes/llama/models/gemma-4-31b-qat-mtp/gemma-4-31B-it-qat-UD-Q4_K_XL.gguf \
  --spec-draft-model /home/hermes/llama/models/gemma-4-31b-qat-mtp/MTP/gemma-4-31B-it-Q4_0-MTP.gguf \
  --spec-type draft-mtp \
  --spec-draft-n-max 2 \
  -c 65536 \
  -b 2048 \
  -ub 512 \
  -ngl 99 \
  -fa on \
  --cache-type-k q4_0 \
  --cache-type-v q4_0 \
  -np 1 \
  --jinja \
  --reasoning off \
  --temp 1.0 \
  --top-p 0.95 \
  --top-k 64 \
  --min-p 0.0 \
  --port 8080 \
  --host 0.0.0.0 \
  --metrics \
  --log-timestamps \
  --log-prefix \
  --log-colors off

Restart=always
RestartSec=5s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
